{
  "permissions": {
    "ask": [
      "Bash(rm *)",
      "Bash(rtk rm *)",
      "Bash(wget *)",
      "Bash(rtk wget *)",
      "Bash(curl *)",
      "Bash(rtk curl *)",
      "Bash(git push*)",
      "Bash(rtk git push*)",
      "Bash(git rm*)",
      "Bash(rtk git rm*)",
      "Bash(gh pr create*)",
      "Bash(rtk gh pr create*)"
    ],
    "deny": [
      "Bash(git reset*)",
      "Bash(rtk git reset*)",
      "Bash(op *)",
      "Bash(cat .env*)",
      "Bash(rtk cat .env*)",
      "Bash(cat **/.env*)",
      "Bash(rtk cat **/.env*)",
      "Bash(cat ~/.kube/config)",
      "Bash(rtk cat ~/.kube/config)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(rm -rf *)",
      "Bash(rtk rm -rf *)",
      "Bash(sudo *)",
      "Read(.env*)",
      "Read(~/.kube/config)"
    ],
    "allow": [
      "Bash(git add*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git commit*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(git log*)",
      "Bash(git pull*)",
      "Bash(git status*)",
      "Bash(git switch*)",
      "Bash(rtk git add*)",
      "Bash(rtk git branch*)",
      "Bash(rtk git checkout*)",
      "Bash(rtk git commit*)",
      "Bash(rtk git diff*)",
      "Bash(rtk git fetch*)",
      "Bash(rtk git log*)",
      "Bash(rtk git pull*)",
      "Bash(rtk git status*)",
      "Bash(rtk git switch*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(rtk gh pr list*)",
      "Bash(rtk gh pr view*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue edit*)",
      "Bash(rtk gh issue view*)",
      "Bash(rtk gh issue list*)",
      "Bash(rtk gh issue edit*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(rtk gh run view*)",
      "Bash(rtk gh run list*)",
      "Bash(cat*)",
      "Bash(cd *)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(pwd*)",
      "Bash(rtk cat*)",
      "Bash(rtk find*)",
      "Bash(rtk grep*)",
      "Bash(rtk ls*)",
      "Bash(rtk mkdir*)",
      "Bash(rtk pwd*)",
      "Bash(home-manager*)",
      "Bash(rtk home-manager*)",
      "Bash(nix *)",
      "Bash(rtk nix *)",
      "Bash(shellcheck*)",
      "Bash(rtk shellcheck*)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh '応答が完了しました'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  }
}
