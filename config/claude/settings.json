{
  "permissions": {
    "allow": [
      "Bash(rtk git branch*)",
      "Bash(rtk git status*)",
      "Bash(rtk git diff*)",
      "Bash(rtk git log*)",
      "Bash(rtk gh pr list*)",
      "Bash(rtk gh pr view*)",
      "Bash(rtk grep*)",
      "Bash(rtk ls*)",
      "Bash(rtk mkdir*)",
      "Bash(rtk pwd*)",
      "Bash(git branch*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(grep*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(pwd*)",
      "Bash(cd *)",
      "WebFetch",
      "WebSearch"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh '応答が完了しました'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  }
}
