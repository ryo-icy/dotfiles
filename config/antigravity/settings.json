{
  "ide": {
    "hasSeenNudge": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true,
    "disableAlwaysAllow": false
  },
  "general": {
    "defaultApprovalMode": "default",
    "enableNotifications": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "hooks": {
    "BeforeAgent": [
      {
        "type": "command",
        "command": "bash ~/.gemini/hooks/notify.sh '応答を待っています...'"
      }
    ],
    "AfterAgent": [
      {
        "type": "command",
        "command": "bash ~/.gemini/hooks/notify.sh '応答が完了しました'"
      }
    ],
    "Notification": [
      {
        "type": "command",
        "command": "bash ~/.gemini/hooks/notify.sh"
      }
    ]
  }
}
